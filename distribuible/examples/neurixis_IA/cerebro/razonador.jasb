clase Razonador

    # =============================================================================
    # 1. razonar
    # =============================================================================
    # Propósito: Realizar razonamiento básico sobre una entrada de texto
    # Parámetros:
    #   - _entrada (texto): Texto de entrada para razonar
    # Retorna:
    #   - texto: Resultado del razonamiento
    # =============================================================================
    enviar funcion razonar(texto _entrada) retorna texto
        # Primero verificar si es un concepto básico conocido
        buscar _entrada
        cuando resultado no es igual a "" entonces
            retornar resultado
        fin_cuando
        
        # Intentar propagación de activación
        propagar_activacion(_entrada)
        
        entero tam
        tam = rastro_activacion_tamano()
        
        cuando tam > 0 entonces
            texto idea
            idea = rastro_activacion_obtener(tam - 1)
            
            # Verificar que la idea obtenida sea útil
            cuando idea no es igual a "" y idea no es igual a _entrada entonces
                retornar idea
            fin_cuando
        fin_cuando
        
        # Si no hay resultados, intentar similitud básica
        cuando contiene_texto(_entrada, "hola") o contiene_texto(_entrada, "buen") entonces
            retornar "hola"
        fin_cuando
        
        cuando contiene_texto(_entrada, "adios") o contiene_texto(_entrada, "chao") entonces
            retornar "adios"
        fin_cuando
        
        cuando contiene_texto(_entrada, "como") o contiene_texto(_entrada, "estas") entonces
            retornar "como_estas"
        fin_cuando
        
        retornar "desconocido"
    fin_funcion
    
    # =============================================================================
