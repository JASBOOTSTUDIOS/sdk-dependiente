{
  "name": "jasboot",
  "displayName": "Jasboot (.jasb)",
  "description": "Sintaxis y comentarios para archivos .jasb (resaltado en el editor).",
  "version": "0.0.4",
  "publisher": "jasboot-local",
  "icon": "img/jasboot-icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/JASBOOTSTUDIO/jasboot-lang.git"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "categories": ["Programming Languages"],
  "scripts": {
    "grammar": "node scripts/gen-keywords-regex.js && node scripts/build-grammar.js",
    "package": "vsce package --no-dependencies",
    "pack": "npm run package"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.1"
  },
  "contributes": {
    "languages": [
      {
        "id": "jasboot",
        "aliases": ["Jasboot", "jasboot"],
        "extensions": [".jasb"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "img/jasboot-icon.png",
          "dark": "img/jasboot-icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "jasboot",
        "scopeName": "source.jasboot",
        "path": "./syntaxes/jasboot.tmLanguage.json"
      }
    ],
    "iconThemes": [
      {
        "id": "jasboot-files",
        "label": "Jasboot (.jasb)",
        "path": "./fileicons/jasboot-icon-theme.json"
      }
    ],
    "configurationDefaults": {
      "[jasboot]": {
        "editor.tokenColorCustomizations": {
          "textMateRules": [
            {
              "scope": "keyword.control.jasboot",
              "settings": { "foreground": "#c678dd", "fontStyle": "bold" }
            },
            {
              "scope": "storage.type.jasboot",
              "settings": { "foreground": "#61afef" }
            },
            {
              "scope": "keyword.operator.word.jasboot",
              "settings": { "foreground": "#56b6c2" }
            },
            {
              "scope": "keyword.control.import.jasboot",
              "settings": { "foreground": "#e5c07b" }
            },
            {
              "scope": "constant.language.jasboot",
              "settings": { "foreground": "#d19a66", "fontStyle": "bold" }
            },
            {
              "scope": "support.function.builtin.io.jasboot",
              "settings": { "foreground": "#98c379" }
            },
            {
              "scope": "support.function.builtin.jasboot",
              "settings": { "foreground": "#7ec699" }
            },
            {
              "scope": "meta.interpolation.jasboot",
              "settings": { "foreground": "#e5c07b" }
            },
            {
              "scope": "punctuation.definition.template-expression.begin.jasboot,punctuation.definition.template-expression.end.jasboot",
              "settings": { "foreground": "#e06c75", "fontStyle": "bold" }
            },
            {
              "scope": "string.quoted.double.jasboot",
              "settings": { "foreground": "#98c379" }
            },
            {
              "scope": "string.quoted.single.concept.jasboot",
              "settings": { "foreground": "#56b6c2" }
            },
            {
              "scope": "comment.line.double-slash.jasboot,comment.line.number-sign.jasboot,comment.block.jasboot",
              "settings": { "foreground": "#7f848e", "fontStyle": "italic" }
            },
            {
              "scope": "constant.numeric.hex.jasboot,constant.numeric.float.jasboot,constant.numeric.integer.jasboot",
              "settings": { "foreground": "#d19a66" }
            },
            {
              "scope": "keyword.operator.arrow.jasboot",
              "settings": { "foreground": "#c678dd", "fontStyle": "bold" }
            },
            {
              "scope": "keyword.operator.comparison.jasboot,keyword.operator.assignment.jasboot",
              "settings": { "foreground": "#61afef" }
            },
            {
              "scope": "keyword.operator.jasboot",
              "settings": { "foreground": "#56b6c2" }
            },
            {
              "scope": "invalid.illegal.name.jasboot",
              "settings": { "foreground": "#e06c75", "fontStyle": "underline" }
            },
            {
              "scope": "variable.other.readwrite.jasboot",
              "settings": { "foreground": "#abb2bf" }
            },
            {
              "scope": "constant.character.escape.jasboot,constant.other.escape.color.jasboot",
              "settings": { "foreground": "#61afef" }
            },
            {
              "scope": "meta.block.interpolation.jasboot,meta.brace.round.jasboot",
              "settings": { "foreground": "#abb2bf" }
            },
            {
              "scope": "punctuation.definition.bracket.jasboot,punctuation.separator.comma.jasboot,punctuation.accessor.jasboot",
              "settings": { "foreground": "#5c6370" }
            }
          ]
        }
      }
    }
  }
}
