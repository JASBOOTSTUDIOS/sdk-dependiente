{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "jasboot",
    "scopeName": "source.jasboot",
    "patterns": [
        {
            "include": "#jasboot_root"
        }
    ],
    "repository": {
        "jasboot_root": {
            "patterns": [
                {
                    "include": "#comments"
                },
                {
                    "include": "#strings_double"
                },
                {
                    "include": "#strings_concept"
                },
                {
                    "include": "#numbers"
                },
                {
                    "include": "#operators"
                },
                {
                    "include": "#keywords_control"
                },
                {
                    "include": "#keywords_storage"
                },
                {
                    "include": "#keywords_word_op"
                },
                {
                    "include": "#keywords_import"
                },
                {
                    "include": "#keywords_constant"
                },
                {
                    "include": "#keywords_io"
                },
                {
                    "include": "#keywords_support_1"
                },
                {
                    "include": "#keywords_support_2"
                },
                {
                    "include": "#forbidden_english"
                },
                {
                    "include": "#identifiers"
                }
            ]
        },
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.jasboot",
                    "match": "//.*"
                },
                {
                    "name": "comment.line.number-sign.jasboot",
                    "match": "#.*"
                },
                {
                    "begin": "/\\*",
                    "end": "\\*/",
                    "patterns": [],
                    "name": "comment.block.jasboot"
                }
            ]
        },
        "strings_double": {
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "include": "#string_escapes"
                },
                {
                    "include": "#string_color_escape"
                },
                {
                    "include": "#interpolation"
                }
            ],
            "name": "string.quoted.double.jasboot"
        },
        "string_escapes": {
            "patterns": [
                {
                    "name": "constant.character.escape.jasboot",
                    "match": "\\\\([nrt\"\\\\]|[eE])"
                },
                {
                    "name": "constant.character.escape.jasboot",
                    "match": "\\\\."
                }
            ]
        },
        "string_color_escape": {
            "patterns": [
                {
                    "name": "constant.other.escape.color.jasboot",
                    "match": "\\\\(normal|negrita|amarillo|magenta|blanco|verde|reset|rojo|verd|amar|azul|mage|cian|blan|negr|norm|rese)\\b"
                }
            ]
        },
        "interpolation": {
            "begin": "\\$\\{",
            "end": "\\}",
            "patterns": [
                {
                    "include": "#interpolated_expr"
                }
            ],
            "name": "meta.interpolation.jasboot",
            "beginCaptures": {
                "0": {
                    "name": "punctuation.definition.template-expression.begin.jasboot"
                }
            },
            "endCaptures": {
                "0": {
                    "name": "punctuation.definition.template-expression.end.jasboot"
                }
            }
        },
        "interpolated_expr": {
            "patterns": [
                {
                    "begin": "\\{",
                    "end": "\\}",
                    "patterns": [
                        {
                            "include": "#interpolated_expr"
                        }
                    ],
                    "name": "meta.block.interpolation.jasboot"
                },
                {
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "include": "#string_escapes"
                        },
                        {
                            "include": "#string_color_escape"
                        }
                    ],
                    "name": "string.quoted.double.jasboot"
                },
                {
                    "include": "#comments"
                },
                {
                    "include": "#numbers"
                },
                {
                    "include": "#operators"
                },
                {
                    "include": "#keywords_control"
                },
                {
                    "include": "#keywords_storage"
                },
                {
                    "include": "#keywords_word_op"
                },
                {
                    "include": "#keywords_import"
                },
                {
                    "include": "#keywords_constant"
                },
                {
                    "include": "#keywords_io"
                },
                {
                    "include": "#keywords_support_1"
                },
                {
                    "include": "#keywords_support_2"
                },
                {
                    "name": "meta.brace.round.jasboot",
                    "match": "[()]"
                },
                {
                    "name": "punctuation.separator.comma.jasboot",
                    "match": ","
                },
                {
                    "name": "variable.other.readwrite.jasboot",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        },
        "strings_concept": {
            "begin": "'",
            "end": "'",
            "patterns": [
                {
                    "name": "constant.character.escape.jasboot",
                    "match": "\\\\."
                }
            ],
            "name": "string.quoted.single.concept.jasboot"
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.jasboot",
                    "match": "\\b0[xX][0-9a-fA-F]+\\b"
                },
                {
                    "name": "constant.numeric.float.jasboot",
                    "match": "\\b\\d+\\.\\d+\\b"
                },
                {
                    "name": "constant.numeric.integer.jasboot",
                    "match": "\\b\\d+\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "name": "keyword.operator.arrow.jasboot",
                    "match": "=>"
                },
                {
                    "name": "keyword.operator.comparison.jasboot",
                    "match": "(===|==|!=|<=|>=|\\+\\+|--|\\+=|-=|\\*=|/=|<<|>>)"
                },
                {
                    "name": "keyword.operator.assignment.jasboot",
                    "match": "="
                },
                {
                    "name": "keyword.operator.jasboot",
                    "match": "[+\\-*/%?:!]"
                },
                {
                    "name": "keyword.operator.jasboot",
                    "match": "[<>=]"
                },
                {
                    "name": "punctuation.accessor.jasboot",
                    "match": "\\."
                },
                {
                    "name": "punctuation.definition.bracket.jasboot",
                    "match": "[()\\[\\]{}]"
                },
                {
                    "name": "punctuation.separator.comma.jasboot",
                    "match": ","
                },
                {
                    "name": "punctuation.terminator.jasboot",
                    "match": ";"
                }
            ]
        },
        "keywords_control": {
            "match": "\\b(fin_seleccionar|fin_principal|fin_mientras|fin_concepto|fin_registro|fin_intentar|fin_funcion|fin_archivo|seleccionar|fin_cuando|principal|continuar|fin_hacer|mientras|retornar|concepto|registro|intentar|funcion|defecto|atrapar|cuando|fin_si|romper|lanzar|llamar|hacer|final|macro|sino|caso|si)\\b",
            "name": "keyword.control.jasboot"
        },
        "keywords_storage": {
            "match": "\\b(constante|flotante|caracter|entero|texto|lista|byte|vec2|vec3|vec4|mat4|mat3|mapa|bool|u32|u64|u8)\\b",
            "name": "storage.type.jasboot"
        },
        "keywords_word_op": {
            "match": "\\b(entonces|distinto|entrada|retorna|valor|igual|mayor|menor|peso|como|con|que|es|no|de|o|y|a)\\b",
            "name": "keyword.operator.word.jasboot"
        },
        "keywords_import": {
            "match": "\\b(enviar|todas|usar|todo)\\b",
            "name": "keyword.control.import.jasboot"
        },
        "keywords_constant": {
            "match": "\\b(verdadero|falso)\\b",
            "name": "constant.language.jasboot"
        },
        "keywords_io": {
            "match": "\\b(imprimir_sin_salto|ingreso_inmediato|imprimir_flotante|limpiar_consola|imprimir_texto|ingresar_texto|imprimir_id|imprimir|decimal)\\b",
            "name": "support.function.builtin.io.jasboot"
        },
        "keywords_support_1": {
            "match": "\\b(rastro_activacion_recientes|ventana_rastro_activacion|rastro_activacion_ventana|rastro_activacion_limpiar|rastro_activacion_obtener|rastro_activacion_tamano|asociar_pesos_conceptos|obtener_todos_conceptos|obtener_nombre_concepto|rastro_activacion_lista|elegir_por_peso_semilla|buscar_asociados_lista|rastro_activacion_peso|propagar_activacion_de|resolver_conflictos_de|mem_aprender_peso_reg|elegir_por_peso_segun|obtener_relacionados|str_extraer_caracter|percepcion_recientes|elegir_por_peso_seed|es_variable_sistema|mem_obtener_u32_ind|percepcion_anterior|propagar_activacion|resolver_conflictos|extraer_despues_de|imprimir_auditoria|propiedad_concepto|leer_linea_archivo|corregir_secuencia|asociar_diferencia|asociados_lista_de|consolidar_memoria|ventana_percepcion|percepcion_limpiar|elegir_por_peso_id|segmentar_palabras|obtener_timestamp|mem_lista_agregar|mem_lista_obtener|mem_poner_u32_ind|asociar_secuencia|comparar_patrones|asociar_similitud|decaer_conexiones|percepcion_tamano|extraer_antes_de|escribir_archivo|pensar_respuesta|sistema_ejecutar|fs_escribir_byte|fs_escribir_byte|str_desde_numero|caracter_a_texto|mem_lista_tamano|tiene_asociacion|registrar_patron|pensar_siguiente|asociar_relacion|buscar_asociados|decae_conexiones|extraer_subtexto|define_concepto|listar_archivos|codigo_caracter|byte_a_caracter|caracter_a_byte|mem_lista_crear|comparar_gt_flt|pensar_anterior|olvidar_debiles|elegir_por_peso|activar_modulo|contiene_texto|ultima_palabra|cerrar_memoria|crear_concepto|cerrar_archivo|existe_archivo|procesar_texto|str_minusculas|str_a_flotante|convertir_flotante|flujo_temporal|longitud_texto|crear_memoria|abrir_archivo|lista_obtener|aprender_peso|lista_agregar|obtener_campo|fs_leer_linea|dividir_texto|copiar_texto|lista_tamano|mapa_obtener|str_a_entero|convertir_entero|fs_leer_byte|asociados_de|buscar_peso)\\b",
            "name": "support.function.builtin.jasboot"
        },
        "keywords_support_2": {
            "match": "\\b(termina_con|crear_lista|fs_escribir|mem_asociar|palabras_de|ir_escribir|biblioteca|str_copiar|mapa_crear|mapa_poner|mem_cerrar|consolidar|percepcion|minusculas|responder|penalizar|finalizar|fs_cerrar|mem_crear|recordar|aprender|reforzar|fs_abrir|sys_argc|sys_argv|reservar|asociar|olvidar|bit_shl|bit_shr|liberar|buscar|pensar|dormir)\\b",
            "name": "support.function.builtin.jasboot"
        },
        "forbidden_english": {
            "match": "\\b(if|else|for|while|function|return|endif|endwhile|endfor|true|false|null|var|let|const|class|import|export)\\b",
            "name": "invalid.illegal.name.jasboot"
        },
        "identifiers": {
            "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b",
            "name": "variable.other.readwrite.jasboot"
        }
    }
}
