/* Test vec2, vec3, vec4 - Prioridad 3: vectores matematica 3D */
principal
    vec3 vector_a = vec3(1.0, 0.0, 0.0)
    vec3 vector_b = vec3(0.0, 1.0, 0.0)
    vec3 vector_c = vector_a + vector_b
    imprimir("Test vec3 - OK")
    flotante len = vec3_longitud(vector_c)
    imprimir_flotante(len)
    vec3 vector_n = vec3(0.0, 0.0, 0.0)
    vec3_normalizar(n, vector_c)
    imprimir_flotante(vector_n.x)
    imprimir_flotante(vector_n.y)
fin_principal
